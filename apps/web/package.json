{
  "name": "@mission-control/web",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "verify:route-chunks": "node ./scripts/verify-route-chunks.mjs",
    "smoke": "npm run build && npm run verify:route-chunks",
    "smoke:preview-routes": "node ./scripts/verify-preview-routes.mjs",
    "verify:playwright-runtime": "node ./scripts/verify-playwright-runtime.mjs",
    "deps:playwright-host": "bash ./scripts/install-playwright-host-deps.sh",
    "smoke:ui": "npm run verify:playwright-runtime && playwright test e2e/release-smoke.spec.ts",
    "release:ui-gate": "bash ./scripts/run-ui-smoke-release.sh",
    "release:ui-readiness": "bash ./scripts/verify-ui-release-gate-readiness.sh",
    "release:ui-handoff": "bash ./scripts/generate-ui-release-handoff.sh",
    "release:ui-handoff-verify": "bash ./scripts/verify-ui-release-handoff-bundle.sh",
    "release:ui-ready-handoff": "bash ./scripts/run-ui-readiness-handoff.sh"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0",
    "@tanstack/react-query": "^5.24.0",
    "axios": "^1.6.0",
    "date-fns": "^3.3.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "socket.io-client": "^4.7.0",
    "@headlessui/react": "^1.7.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "lucide-react": "^0.344.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@playwright/test": "^1.53.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  }
}
